# Copy this file to .env.local and fill in real values.
# .env.local is never committed to git — it's just for your machine
# (and separately configured in Vercel for the live site).

# --- Supabase (database + auth) — added in Milestone 1 ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Claude API (AI-drafted emails) — added in Milestone 6 ---
ANTHROPIC_API_KEY=

# --- Resend (sending emails) — added in Milestone 7 ---
RESEND_API_KEY=

# Note: each user's own Stripe restricted key is NOT an env variable —
# it's entered by the user in the app and stored encrypted in the
# database, since every user has a different Stripe account.
